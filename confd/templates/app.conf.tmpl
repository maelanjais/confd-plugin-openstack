# Generated by confd-plugin-openstack
# Last updated: {{datetime}}

[database]
# Dynamically found DB from OpenStack metadata
{{- range $name := ls "/vms"}}
{{- $role := getv (printf "/vms/%s/meta/role" $name) ""}}
{{- if eq $role "db"}}
{{- $ip   := getv (printf "/vms/%s/ip" $name) ""}}
{{- $port := getv (printf "/vms/%s/meta/app_port" $name) "5432"}}
endpoint = {{$ip}}:{{$port}}
{{- end}}
{{- end}}
